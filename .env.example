# Copy this file to config.env and update paths for your machine.
LAMMPS_ROOT=/path/to/lammps
GNNP_ROOT=/path/to/lammps/src/ML-GNNP

# Each model can use a different LAMMPS binary because its Python environment
# may be linked at compile time.
MACE_LMP_BIN=/path/to/lmp_mace
CHGNET_LMP_BIN=/path/to/lmp_chgnet
MATGL_LMP_BIN=/path/to/lmp_matgl
SEVENNET_LMP_BIN=/path/to/lmp_sevennet
MATTERSIM_LMP_BIN=/path/to/lmp_mattersim
ORB_LMP_BIN=/path/to/lmp_orb
EQV2M_LMP_BIN=/path/to/lmp_eqv2m
