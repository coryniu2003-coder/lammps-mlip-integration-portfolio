variable gnnp_root string ${gnnp_root}
variable structure string "../../structures/argon_fcc_4.lammps"

units metal
boundary p p p
atom_style atomic
log log.orb_short
pair_style gnnp ${gnnp_root}
read_data ${structure}
pair_coeff * * orb orb-v2 Ar
dump dump_all all custom 10 xyz_short.lammpstrj id element x y z
dump_modify dump_all sort id element Ar
thermo_style custom step time temp pe etotal press
thermo 10
velocity all create 300.0 12345
fix nvt all nvt temp 300.0 300.0 0.1
timestep 5.0e-4
run 2000
